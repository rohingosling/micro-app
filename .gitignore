# Public repository .gitignore.
#
# This file is OWNED by the public repo and preserved across promotions -- it is
# never overwritten by tools/promote. Keep it free of any reference to private,
# dev-only paths (those must never leave a trace in the public tree).

# DOS build artifacts -- regenerated by test\build.bat. Both cases: DOS tools
# emit upper-case names.
*.obj
*.OBJ
*.exe
*.EXE
build.log
BUILD.LOG

# DOSBox console dumps.
stdout.txt
stderr.txt

# Backups and temp files.
*.bak
*.tmp

# IDE / editor
.idea/
.vscode/
.vs/

# OS junk
.DS_Store
Thumbs.db
